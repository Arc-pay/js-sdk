{
  "name": "arc-pay",
  "version": "0.1.0",
  "description": "Arc Pay browser SDK — publishable-key tokenization, Hosted Fields, and React bindings",
  "private": false,
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./js": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "@arcpay/api-client": "workspace:*"
  },
  "scripts": {
    "build": "tsup",
    "build:cdn": "BUILD=cdn tsup",
    "build:all": "pnpm build && pnpm build:cdn",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "size": "node ./scripts/check-bundle-size.mjs",
    "e2e": "pnpm build:all && playwright test --config=e2e/playwright.config.ts",
    "e2e:install": "playwright install --with-deps chromium firefox webkit",
    "e2e:headed": "playwright test --config=e2e/playwright.config.ts --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "http-server": "^14.1.1",
    "jsdom": "^25.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
